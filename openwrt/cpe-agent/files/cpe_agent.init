#!/bin/sh /etc/rc.common
# procd init for cpe_agent (perf NDJSON → stdout / Vector)

START=96
USE_PROCD=1

CONFIG=/etc/cpe_agent/cpe_agent.yaml

start_service() {
	procd_open_instance
	procd_set_param command /usr/sbin/cpe_agent \
		--config "$CONFIG" \
		--router-id "$(cat /proc/sys/kernel/hostname 2>/dev/null || echo cpe)"
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	# SIGHUP: re-read /etc/cpe_agent/cpe_agent.yaml; --router-id override kept
	procd_send_signal cpe-agent '*' HUP
}
