        }
      ],
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" }
    },
    {
      "type": "timeseries",
      "title": "CPE ping loss",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT ts AS time, loss, router_id FROM forensics.cpe_perf_samples WHERE probe = 'ping' AND $__timeFilter(ts) AND router_id = '${router_id}' ORDER BY ts",
          "format": 1,
          "refId": "A"
        }
      ],
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" }
    },
